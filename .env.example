# LLM Provider (deepseek | openai | claude)
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Alternative providers (optional)
OPENAI_API_KEY=sk-your-openai-key
CLAUDE_API_KEY=sk-ant-your-claude-key

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# WeChat Official Account
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_app_secret

# Scheduler (Asia/Shanghai)
PUBLISH_CRON=0 9 * * 1-5
TOPIC_REFRESH_CRON=0 8 * * 1-5

# Startup
DEFAULT_HUMAN_MODE=dry-run
DEFAULT_SESSION_ID=default

# News API for real-time topic generation (https://newsapi.org)
NEWSAPI_KEY=your-newsapi-key

# Google Custom Search API (https://developers.google.com/custom-search)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CSE_ID=your-custom-search-engine-id

# Proxy (optional)
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897
